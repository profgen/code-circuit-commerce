{
  "name": "code-circuit-commerce",
  "version": "0.1.0",
  "private": true,
  "description": "AI-first e-commerce platform monorepo",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "preview:up": "docker compose -f docker-compose.preview.yml up -d --build",
    "preview:down": "docker compose -f docker-compose.preview.yml down",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "pnpm -r format",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky"
  },
  "keywords": [
    "ecommerce",
    "monorepo",
    "nextjs",
    "nestjs"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
